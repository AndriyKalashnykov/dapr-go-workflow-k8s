# Committed source of truth for operator-tunable values. Copy to `.env`
# (gitignored) to override locally; shell scripts source this file first, then
# `.env`. Every value here is also mirrored as a default in the Makefile (`?=`),
# the application code (os.Getenv fallback), and the Dockerfile (ARG/ENV).

# --- Application ---
# HTTP listen port. MUST match the Dapr sidecar's --app-port (run-dapr.sh).
APP_PORT=7999
# Host the container HEALTHCHECK probe dials.
HEALTHCHECK_HOST=localhost

# --- Dapr sidecar ---
DAPR_APP_ID=sample
DAPR_GRPC_PORT=50001

# --- PostgreSQL (local dev state store; see run-postgres.sh) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=daprrulz
POSTGRES_DB=sample_state

# --- Container image ---
IMAGE_REGISTRY=ghcr.io
REGISTRY_OWNER=andriykalashnykov
